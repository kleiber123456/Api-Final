  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Script global para agregar token automáticamente",
          "if (pm.collectionVariables.get('token')) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + pm.collectionVariables.get('token')",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "🔐 Autenticación",
      "description": "Endpoints para autenticación y recuperación de contraseña",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    if (response.token) {",
                  "        pm.collectionVariables.set('token', response.token);",
                  "        pm.collectionVariables.set('user_id', response.usuario.id);",
                  "        console.log('✅ Token guardado automáticamente');",
                  "        console.log('👤 Usuario:', response.usuario.nombre);",
                  "        console.log('🎭 Rol:', response.usuario.rol.nombre);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@motortega.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "🔑 **Campos requeridos:**\n- email: Correo electrónico del usuario\n- password: Contraseña del usuario\n\n**Usuarios de prueba:**\n- Admin: admin@motortega.com / admin123\n- Mecánico: mecanico@motortega.com / mecanico123\n- Cliente: cliente@motortega.com / cliente123"
